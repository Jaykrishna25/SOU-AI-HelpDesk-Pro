# ---------- Database ----------
DATABASE_URL="postgresql://sou_admin:sou_secret@localhost:5432/sou_helpdesk?schema=public"

# ---------- Auth ----------
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="7d"

# ---------- Server ----------
PORT=5001
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"

# ---------- AI Layer ----------
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"
EMBEDDING_MODEL="text-embedding-3-small"
AI_CONFIDENCE_THRESHOLD=0.90

# ---------- AWS ----------
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET="sou-helpdesk-assets"
SES_FROM_EMAIL="no-reply@silveroakuni.ac.in"

# ---------- SLA ----------
ADMIN_RESPONSE_SLA_HOURS=48

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL="http://localhost:5001/api"
